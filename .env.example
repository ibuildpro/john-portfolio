# Preferred contact form provider: Resend
# Create an API key and verify a sending domain in Resend, then set:
RESEND_API_KEY=
RESEND_FROM="Johnathan Hyde <contact@johnathan.app>"
CONTACT_TO=super.boom0510@gmail.com

# Optional public fallback. If Resend/SMTP is not configured, the form can open
# the visitor's email app with a prefilled draft to this public address.
CONTACT_PUBLIC_EMAIL=super.boom0510@gmail.com

# SMTP fallback. Use these instead of Resend if you prefer your mailbox provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
